        ["sql-select-compact-max-items"] = SelectCompactThresholdExampleSql,
        ["sql-select-compact-max-line-length"] = SelectCompactLineLengthExampleSql,
        ["sql-in-list-items-style"] = ListsExampleSql,
        ["sql-inline-in-list-max-items"] = InListThresholdExampleSql,
        ["sql-inline-in-list-max-line"] = InListThresholdExampleSql,
        ["sql-update-set-style"] = DmlAndDdlExampleSql,
        ["sql-insert-columns-style"] = DmlAndDdlExampleSql,
        ["sql-insert-values-style"] = DmlAndDdlExampleSql,
        ["sql-create-proc-layout"] = CreateProcLayoutExampleSql,
        ["sql-comments-preserve-attachment"] = CommentsExampleSql,
        ["sql-comments-formatting"] = CommentsExampleSql,
        ["sql-inside-parentheses"] = SpacingExampleSql,
        ["sql-spaces-after-comma"] = SpacingExampleSql,
        ["sql-spaces-around-binary-operators"] = SpacingExampleSql,
        ["sql-spaces-before-semicolon"] = SpacingExampleSql
    };

    private string sourceSql = DemoSql;
    private string formattedSql = string.Empty;
    private string? formattingError;
    private string optionSearch = string.Empty;
    private bool autoFormat = true;
    private bool autoFormatOptions = true;

    private SqlKeywordCase keywordCase = SqlKeywordCase.Upper;
    private SqlParenthesesSpacing insideParentheses = SqlParenthesesSpacing.Never;
    private SqlStatementTerminationMode terminateWithSemicolon = SqlStatementTerminationMode.ExistingOnly;
    private bool blankLineBetweenClauses;
    private SqlCommaStyle commaStyle = SqlCommaStyle.Trailing;
    private SqlListLayoutStyle selectItemsStyle = SqlListLayoutStyle.OnePerLine;
    private SqlListLayoutStyle groupByItemsStyle = SqlListLayoutStyle.OnePerLine;
    private SqlListLayoutStyle orderByItemsStyle = SqlListLayoutStyle.OnePerLine;
    private SqlInListItemsStyle inListItemsStyle = SqlInListItemsStyle.Inline;

    private bool spacesAfterComma = true;
    private bool spacesAroundBinaryOperators = true;
    private bool spacesBeforeSemicolon = false;
    private bool eofNewline;
    private bool alignSelectAliases;
    private bool joinsNewlinePerJoin = true;
    private bool joinsOnNewLine = true;
    private bool joinsMultilineOnBreakOnAnd = true;
    private bool joinsMultilineOnBreakOnOr;
    private int joinsMultilineOnMaxTokensSingleLine;
    private bool predicatesMultilineWhere;
    private SqlLogicalOperatorLineBreakMode predicatesLogicalOperatorLineBreak = SqlLogicalOperatorLineBreakMode.BeforeOperator;
    private int predicatesInlineSimpleMaxConditions;
    private int predicatesInlineSimpleMaxLineLength = 120;
    private bool predicatesInlineSimpleAllowOnlyAnd = true;
    private bool predicatesMixedAndOrParenthesizeOrGroups;
    private bool predicatesMixedAndOrBreakOrGroups;
    private SqlCaseStyle expressionsCaseStyle = SqlCaseStyle.Multiline;
    private int compactCaseMaxWhenClauses;
    private int compactCaseMaxTokens;
    private int compactCaseMaxLineLength = 120;
    private int inlineShortExpressionMaxTokens;
    private int inlineShortExpressionMaxDepth;
    private int inlineShortExpressionMaxLineLength = 120;
    private bool inlineShortContextSelectItem;
    private bool inlineShortContextOn;
    private bool inlineShortContextWhere;
    private bool shortQueriesEnabled;
    private int shortQueriesMaxLineLength = 100;
    private int shortQueriesMaxSelectItems = 2;
    private int shortQueriesMaxPredicateConditions = 2;
    private bool shortQueriesApplyToParenthesizedSubqueries;
    private bool shortQueriesAllowSingleJoin;
    private SqlDmlListStyle updateSetStyle = SqlDmlListStyle.OnePerLine;
    private SqlDmlListStyle insertColumnsStyle = SqlDmlListStyle.OnePerLine;
    private SqlDmlListStyle insertValuesStyle = SqlDmlListStyle.OnePerLine;
    private SqlCreateProcLayout createProcLayout = SqlCreateProcLayout.Expanded;
    private bool commentsPreserveAttachment = true;
    private SqlCommentsFormattingMode commentsFormatting = SqlCommentsFormattingMode.Keep;

    private bool newlineBeforeWith = true;
    private bool newlineBeforeSelect = true;
    private bool newlineBeforeFrom = true;
    private bool newlineBeforeWhere = true;
    private bool newlineBeforeGroupBy = true;
    private bool newlineBeforeHaving = true;
    private bool newlineBeforeOrderBy = true;
    private bool newlineBeforeOption = true;

    private int indentSize = 4;
    private int wrapColumn = 120;
    private int selectCompactMaxItems;
    private int selectCompactMaxLineLength = 120;
    private int inlineInListMaxItems;
    private int inlineInListMaxLineLength = 120;
    private bool resizeEditorsPending = true;
    private bool isFormatterInitializing;
    private bool isFormatterInitialized;

    private bool spacesInsideParentheses
    {
        get => insideParentheses == SqlParenthesesSpacing.Always;
        set => insideParentheses = value
            ? SqlParenthesesSpacing.Always
            : SqlParenthesesSpacing.Never;
    }

    private bool areJoinBreakOptionsEnabled => joinsMultilineOnMaxTokensSingleLine > 0;

    private bool arePredicateMultilineLayoutSettingsEnabled => predicatesMultilineWhere;

    private bool arePredicateInlineSettingsEnabled => predicatesMultilineWhere;

    private bool arePredicateInlineSecondarySettingsEnabled =>
        predicatesMultilineWhere && predicatesInlineSimpleMaxConditions > 0;

    private bool areCompactCaseThresholdsEnabled => expressionsCaseStyle == SqlCaseStyle.CompactWhenShort;

    private bool areInlineShortSecondarySettingsEnabled => inlineShortExpressionMaxTokens > 0;

    private bool areInlineShortContextsSelected =>
        inlineShortContextSelectItem ||
        inlineShortContextOn ||
        inlineShortContextWhere;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await InitializeFormatterAsync();
        }

        if (!firstRender && !resizeEditorsPending)
        {
            return;
        }

        resizeEditorsPending = false;
        await JsRuntime.InvokeVoidAsync(
            "dslkitSqlEditor.autoSizeTextAreaById",
            "sql-source-input",
            170);
    }

    private async Task InitializeFormatterAsync()
    {
        if (isFormatterInitialized || isFormatterInitializing)
        {
            return;
        }

        isFormatterInitializing = true;
        formattingError = null;
        formattedSql = string.Empty;
        await InvokeAsync(StateHasChanged);

        await Task.Yield();
        FormatCurrentSql();

        isFormatterInitializing = false;
        isFormatterInitialized = true;
        resizeEditorsPending = true;
        await InvokeAsync(StateHasChanged);
    }

    private string GetSourcePreview()
    {
        var sourcePreview = string.Join(' ', sourceSql.Split((char[]?)null, StringSplitOptions.RemoveEmptyEntries));
        if (string.IsNullOrWhiteSpace(sourcePreview))
        {
            return "(empty)";
        }

        return sourcePreview.Length <= SourcePreviewLength
            ? sourcePreview
            : $"{sourcePreview[..SourcePreviewLength]}...";
    }

    private bool HideOption(string searchTokens) => !MatchesOptionSearch(searchTokens);

    private static string GetPropertyRowClass(bool disabled, bool isCheck = false)
    {
        var cssClass = isCheck
            ? "dsl-sql-property-row dsl-sql-property-row--check"
            : "dsl-sql-property-row";
        return disabled ? $"{cssClass} dsl-sql-property-row--disabled" : cssClass;
    }

    private bool MatchesOptionSearch(string searchTokens)
    {
        if (string.IsNullOrWhiteSpace(optionSearch))
        {
            return true;
        }

        return searchTokens.Contains(optionSearch.Trim(), StringComparison.OrdinalIgnoreCase);
    }

    private Task OnSourceInputAsync(ChangeEventArgs args)
    {
        if (isFormatterInitializing)
        {
            return Task.CompletedTask;
        }

        sourceSql = args.Value?.ToString() ?? string.Empty;
        if (autoFormat)
        {
            FormatCurrentSql();
        }
        else
        {
            resizeEditorsPending = true;
        }

        return Task.CompletedTask;
    }

    private async Task OnOptionsChangedAsync(ChangeEventArgs _)
    {
        await OnOptionValueChangedAsync();
    }

    private async Task OnOptionValueChangedAsync()
    {
        if (isFormatterInitializing)
        {
            return;
        }

        await Task.Yield();
        if (autoFormatOptions)
        {
            FormatCurrentSql();
        }
    }

    private Task OnLoadDemoRequestedAsync()
    {
        if (isFormatterInitializing)
        {
            return Task.CompletedTask;
        }

        sourceSql = DemoSql;
        FormatCurrentSql();
        return Task.CompletedTask;
    }

    private Task OnOptionExampleRequestedAsync(string optionId)
    {
        if (isFormatterInitializing)
        {
            return Task.CompletedTask;
        }

        if (!OptionExamples.TryGetValue(optionId, out var optionExampleSql))
        {
            return Task.CompletedTask;
        }

        ApplyOptionExamplePreset(optionId);
        sourceSql = optionExampleSql;
        FormatCurrentSql();
        return Task.CompletedTask;
    }

    private void ApplyOptionExamplePreset(string optionId)
    {
        var isJoinBreakOption = string.Equals(optionId, "sql-joins-break-on-and", StringComparison.Ordinal) ||
            string.Equals(optionId, "sql-joins-break-on-or", StringComparison.Ordinal) ||
            string.Equals(optionId, "sql-joins-multiline-threshold", StringComparison.Ordinal);
        if (isJoinBreakOption && joinsMultilineOnMaxTokensSingleLine == 0)
        {
            joinsMultilineOnMaxTokensSingleLine = 12;
        }

        if (string.Equals(optionId, "sql-joins-break-on-and", StringComparison.Ordinal))
        {
            joinsMultilineOnBreakOnAnd = true;
        }

        if (string.Equals(optionId, "sql-joins-break-on-or", StringComparison.Ordinal))
        {
            joinsMultilineOnBreakOnOr = true;
        }

        var isPredicateInlineOption = string.Equals(optionId, "sql-predicates-inline-max-conditions", StringComparison.Ordinal) ||
            string.Equals(optionId, "sql-predicates-inline-max-line-length", StringComparison.Ordinal) ||
            string.Equals(optionId, "sql-predicates-inline-allow-only-and", StringComparison.Ordinal);
        if (isPredicateInlineOption)
        {
            predicatesMultilineWhere = true;
            if (predicatesInlineSimpleMaxConditions == 0)
            {
                predicatesInlineSimpleMaxConditions = 2;
            }
        }

        if (string.Equals(optionId, "sql-predicates-inline-max-line-length", StringComparison.Ordinal))
        {
            predicatesInlineSimpleMaxConditions = Math.Max(predicatesInlineSimpleMaxConditions, 4);
        }

        if (string.Equals(optionId, "sql-predicates-inline-allow-only-and", StringComparison.Ordinal))
        {
            predicatesInlineSimpleMaxConditions = Math.Max(predicatesInlineSimpleMaxConditions, 2);
            predicatesInlineSimpleMaxLineLength = Math.Max(predicatesInlineSimpleMaxLineLength, 120);
        }

        var isMixedAndOrOption = string.Equals(optionId, "sql-predicates-mixed-and-or-parenthesize-or-groups", StringComparison.Ordinal) ||
            string.Equals(optionId, "sql-predicates-mixed-and-or-break-or-groups", StringComparison.Ordinal);
        if (isMixedAndOrOption)
        {
            predicatesMultilineWhere = true;
        }

        if (string.Equals(optionId, "sql-predicates-logical-break", StringComparison.Ordinal))
        {
            predicatesMultilineWhere = true;
        }

        var isCaseThresholdOption = string.Equals(optionId, "sql-case-threshold-max-when", StringComparison.Ordinal) ||
            string.Equals(optionId, "sql-case-threshold-max-line", StringComparison.Ordinal);
        if (isCaseThresholdOption)
        {
            expressionsCaseStyle = SqlCaseStyle.CompactWhenShort;
        }

        var isInlineShortOption = string.Equals(optionId, "sql-inline-short-max-tokens", StringComparison.Ordinal) ||
            string.Equals(optionId, "sql-inline-short-max-line", StringComparison.Ordinal) ||
            string.Equals(optionId, "sql-inline-short-select-item", StringComparison.Ordinal) ||
            string.Equals(optionId, "sql-inline-short-on", StringComparison.Ordinal) ||
            string.Equals(optionId, "sql-inline-short-where", StringComparison.Ordinal);
        if (isInlineShortOption)
        {
            selectItemsStyle = SqlListLayoutStyle.OnePerLine;
            joinsMultilineOnMaxTokensSingleLine = Math.Max(joinsMultilineOnMaxTokensSingleLine, 12);
            joinsMultilineOnBreakOnAnd = true;
            predicatesMultilineWhere = true;
            inlineShortExpressionMaxTokens = Math.Max(inlineShortExpressionMaxTokens, 20);
            inlineShortExpressionMaxLineLength = Math.Max(inlineShortExpressionMaxLineLength, 120);
        }

        if (string.Equals(optionId, "sql-inline-short-max-tokens", StringComparison.Ordinal) ||
            string.Equals(optionId, "sql-inline-short-max-line", StringComparison.Ordinal))
        {
            inlineShortContextSelectItem = true;
            inlineShortContextOn = true;
            inlineShortContextWhere = true;
        }

        if (string.Equals(optionId, "sql-inline-short-max-tokens", StringComparison.Ordinal))
        {
            inlineShortExpressionMaxTokens = 12;
            inlineShortExpressionMaxLineLength = Math.Max(inlineShortExpressionMaxLineLength, 120);
        }

        if (string.Equals(optionId, "sql-inline-short-select-item", StringComparison.Ordinal))
        {
            inlineShortContextSelectItem = true;
            inlineShortContextOn = false;
            inlineShortContextWhere = false;
        }

        if (string.Equals(optionId, "sql-inline-short-on", StringComparison.Ordinal))
        {
            inlineShortContextSelectItem = false;
            inlineShortContextOn = true;
            inlineShortContextWhere = false;
        }

        if (string.Equals(optionId, "sql-inline-short-where", StringComparison.Ordinal))
        {
            inlineShortContextSelectItem = false;
            inlineShortContextOn = false;
            inlineShortContextWhere = true;
        }

        var isShortQueryOption = string.Equals(optionId, "sql-short-queries-enabled", StringComparison.Ordinal) ||
            string.Equals(optionId, "sql-short-queries-max-line-length", StringComparison.Ordinal) ||
            string.Equals(optionId, "sql-short-queries-max-select-items", StringComparison.Ordinal) ||
            string.Equals(optionId, "sql-short-queries-max-predicate-conditions", StringComparison.Ordinal) ||
            string.Equals(optionId, "sql-short-queries-apply-to-parenthesized-subqueries", StringComparison.Ordinal) ||
            string.Equals(optionId, "sql-short-queries-allow-single-join", StringComparison.Ordinal);
        if (isShortQueryOption)
        {
            shortQueriesEnabled = true;
            shortQueriesMaxLineLength = Math.Max(60, shortQueriesMaxLineLength);
            shortQueriesMaxSelectItems = Math.Max(2, shortQueriesMaxSelectItems);
            shortQueriesMaxPredicateConditions = Math.Max(2, shortQueriesMaxPredicateConditions);
        }

        if (string.Equals(optionId, "sql-short-queries-apply-to-parenthesized-subqueries", StringComparison.Ordinal))
        {
            shortQueriesApplyToParenthesizedSubqueries = true;
        }

        if (string.Equals(optionId, "sql-short-queries-allow-single-join", StringComparison.Ordinal))
        {
            shortQueriesAllowSingleJoin = true;
        }

        var isSelectCompactOption = string.Equals(optionId, "sql-select-compact-max-items", StringComparison.Ordinal) ||
            string.Equals(optionId, "sql-select-compact-max-line-length", StringComparison.Ordinal);
        if (isSelectCompactOption)
        {
            selectItemsStyle = SqlListLayoutStyle.OnePerLine;
            selectCompactMaxItems = Math.Max(2, selectCompactMaxItems);
            selectCompactMaxLineLength = Math.Max(40, selectCompactMaxLineLength);
        }

        if (string.Equals(optionId, "sql-select-compact-max-items", StringComparison.Ordinal))
        {
            selectCompactMaxItems = 1;
            selectCompactMaxLineLength = Math.Max(120, selectCompactMaxLineLength);
        }

        if (string.Equals(optionId, "sql-select-compact-max-line-length", StringComparison.Ordinal))
        {
            selectCompactMaxItems = Math.Max(2, selectCompactMaxItems);
            selectCompactMaxLineLength = 40;
        }

        var isInlineInListOption = string.Equals(optionId, "sql-inline-in-list-max-items", StringComparison.Ordinal) ||
            string.Equals(optionId, "sql-inline-in-list-max-line", StringComparison.Ordinal);
        if (isInlineInListOption)
        {
            inListItemsStyle = SqlInListItemsStyle.OnePerLine;
        }

        if (string.Equals(optionId, "sql-wrap-column", StringComparison.Ordinal))
        {
            selectItemsStyle = SqlListLayoutStyle.WrapByWidth;
            groupByItemsStyle = SqlListLayoutStyle.WrapByWidth;
            orderByItemsStyle = SqlListLayoutStyle.WrapByWidth;
            inListItemsStyle = SqlInListItemsStyle.WrapByWidth;
            wrapColumn = 60;
        }
    }

    private Task OnFormatRequestedAsync()
    {
        if (isFormatterInitializing)
        {
            return Task.CompletedTask;
        }

        FormatCurrentSql();
        return Task.CompletedTask;
    }

    private Task OnResetOptionsRequestedAsync()
    {
        if (isFormatterInitializing)
        {
            return Task.CompletedTask;
        }

        ApplyDefaultOptions();
        FormatCurrentSql();
        return Task.CompletedTask;
    }

    private void ApplyDefaultOptions()
    {
        keywordCase = SqlKeywordCase.Upper;
        insideParentheses = SqlParenthesesSpacing.Never;
        terminateWithSemicolon = SqlStatementTerminationMode.ExistingOnly;
        blankLineBetweenClauses = false;
        commaStyle = SqlCommaStyle.Trailing;
        selectItemsStyle = SqlListLayoutStyle.OnePerLine;
        groupByItemsStyle = SqlListLayoutStyle.OnePerLine;
        orderByItemsStyle = SqlListLayoutStyle.OnePerLine;

        spacesAfterComma = true;
        spacesAroundBinaryOperators = true;
        spacesBeforeSemicolon = false;
        eofNewline = false;
        alignSelectAliases = false;
        joinsNewlinePerJoin = true;
        joinsOnNewLine = true;
        joinsMultilineOnBreakOnAnd = true;
        joinsMultilineOnBreakOnOr = false;
        joinsMultilineOnMaxTokensSingleLine = 0;
        predicatesMultilineWhere = false;
        predicatesLogicalOperatorLineBreak = SqlLogicalOperatorLineBreakMode.BeforeOperator;
        predicatesInlineSimpleMaxConditions = 0;
        predicatesInlineSimpleMaxLineLength = 120;
        predicatesInlineSimpleAllowOnlyAnd = true;
        predicatesMixedAndOrParenthesizeOrGroups = false;
        predicatesMixedAndOrBreakOrGroups = false;
        expressionsCaseStyle = SqlCaseStyle.Multiline;
        compactCaseMaxWhenClauses = 0;
        compactCaseMaxTokens = 0;
        compactCaseMaxLineLength = 120;
        inlineShortExpressionMaxTokens = 0;
        inlineShortExpressionMaxDepth = 0;
        inlineShortExpressionMaxLineLength = 120;
        inlineShortContextSelectItem = false;
        inlineShortContextOn = false;
        inlineShortContextWhere = false;
        shortQueriesEnabled = false;
        shortQueriesMaxLineLength = 100;
        shortQueriesMaxSelectItems = 2;
        shortQueriesMaxPredicateConditions = 2;
        shortQueriesApplyToParenthesizedSubqueries = false;
        shortQueriesAllowSingleJoin = false;
        inListItemsStyle = SqlInListItemsStyle.Inline;
        inlineInListMaxItems = 0;
        inlineInListMaxLineLength = 120;
        updateSetStyle = SqlDmlListStyle.OnePerLine;
        insertColumnsStyle = SqlDmlListStyle.OnePerLine;
        insertValuesStyle = SqlDmlListStyle.OnePerLine;
        createProcLayout = SqlCreateProcLayout.Expanded;
        commentsPreserveAttachment = true;
        commentsFormatting = SqlCommentsFormattingMode.Keep;

        newlineBeforeWith = true;
        newlineBeforeSelect = true;
        newlineBeforeFrom = true;
        newlineBeforeWhere = true;
        newlineBeforeGroupBy = true;
        newlineBeforeHaving = true;
        newlineBeforeOrderBy = true;
        newlineBeforeOption = true;

        indentSize = 4;
        wrapColumn = 120;
        selectCompactMaxItems = 0;
        selectCompactMaxLineLength = 120;
    }

    private void FormatCurrentSql()
    {
        try
        {
            var options = new SqlFormattingOptions
            {
                KeywordCase = keywordCase,
                Spaces = new SqlSpacesFormattingOptions
                {
                    AfterComma = spacesAfterComma,
                    AroundBinaryOperators = spacesAroundBinaryOperators,
                    InsideParentheses = insideParentheses,
                    BeforeSemicolon = spacesBeforeSemicolon
                },
                Statement = new SqlStatementFormattingOptions
                {
                    TerminateWithSemicolon = terminateWithSemicolon
                },
                Eof = new SqlEndOfFileFormattingOptions
                {
                    Newline = eofNewline
                },
                Layout = new SqlLayoutFormattingOptions
                {
                    IndentSize = Math.Max(1, indentSize),
                    WrapColumn = Math.Max(10, wrapColumn),
                    NewlineBeforeClause = new SqlClauseNewlineOptions
                    {
                        With = newlineBeforeWith,
                        Select = newlineBeforeSelect,
                        From = newlineBeforeFrom,
                        Where = newlineBeforeWhere,
                        GroupBy = newlineBeforeGroupBy,
                        Having = newlineBeforeHaving,
                        OrderBy = newlineBeforeOrderBy,
                        Option = newlineBeforeOption
                    },
                    BlankLineBetweenClauses = blankLineBetweenClauses
                        ? SqlBlankLineBetweenClausesMode.BetweenMajorClauses
                        : SqlBlankLineBetweenClausesMode.None
                },
                Lists = new SqlListsFormattingOptions
                {
                    CommaStyle = commaStyle,
                    SelectItems = selectItemsStyle,
                    GroupByItems = groupByItemsStyle,
                    OrderByItems = orderByItemsStyle,
                    InListItems = inListItemsStyle,
                    SelectCompactThreshold = new SqlSelectCompactThresholdOptions
                    {
                        MaxItems = Math.Max(0, selectCompactMaxItems),
                        MaxLineLength = Math.Max(10, selectCompactMaxLineLength)
                    },
                    InlineInListThreshold = new SqlInlineInListThresholdOptions
                    {
                        MaxItemsInline = Math.Max(0, inlineInListMaxItems),
                        MaxLineLength = Math.Max(10, inlineInListMaxLineLength)
                    }
                },
                Align = new SqlAlignFormattingOptions
                {
                    SelectAliases = alignSelectAliases
                },
                Joins = new SqlJoinsFormattingOptions
                {
                    NewlinePerJoin = joinsNewlinePerJoin,
                    OnNewLine = joinsOnNewLine,
                    MultilineOnThreshold = new SqlJoinMultilineOnThresholdOptions
                    {
                        MaxTokensSingleLine = Math.Max(0, joinsMultilineOnMaxTokensSingleLine),
                        BreakOnAnd = joinsMultilineOnBreakOnAnd,
                        BreakOnOr = joinsMultilineOnBreakOnOr
                    }
                },
                Predicates = new SqlPredicatesFormattingOptions
                {
                    MultilineWhere = predicatesMultilineWhere,
                    LogicalOperatorLineBreak = predicatesLogicalOperatorLineBreak,
                    InlineSimplePredicate = new SqlInlineSimplePredicateOptions
                    {
                        MaxConditions = Math.Max(0, predicatesInlineSimpleMaxConditions),
                        MaxLineLength = Math.Max(10, predicatesInlineSimpleMaxLineLength),
                        AllowOnlyAnd = predicatesInlineSimpleAllowOnlyAnd
                    },
                    MixedAndOrParentheses = new SqlMixedAndOrParenthesesOptions
                    {
                        ParenthesizeOrGroups = predicatesMixedAndOrParenthesizeOrGroups,
                        BreakOrGroups = predicatesMixedAndOrBreakOrGroups
                    }
                },
                Expressions = new SqlExpressionsFormattingOptions
                {
                    CaseStyle = expressionsCaseStyle,
                    CompactCaseThreshold = new SqlCompactCaseThresholdOptions
                    {
                        MaxWhenClauses = Math.Max(0, compactCaseMaxWhenClauses),
                        MaxTokens = Math.Max(0, compactCaseMaxTokens),
                        MaxLineLength = Math.Max(10, compactCaseMaxLineLength)
                    },
                    InlineShortExpression = new SqlInlineShortExpressionOptions
                    {
                        MaxTokens = Math.Max(0, inlineShortExpressionMaxTokens),
                        MaxDepth = Math.Max(0, inlineShortExpressionMaxDepth),
                        MaxLineLength = Math.Max(10, inlineShortExpressionMaxLineLength),
                        ForContexts = BuildInlineShortExpressionContexts()
                    }
                },
                ShortQueries = new SqlShortQueriesFormattingOptions
                {
                    Enabled = shortQueriesEnabled,
                    MaxLineLength = Math.Max(10, shortQueriesMaxLineLength),
                    MaxSelectItems = Math.Max(1, shortQueriesMaxSelectItems),
                    MaxPredicateConditions = Math.Max(1, shortQueriesMaxPredicateConditions),
                    ApplyToParenthesizedSubqueries = shortQueriesApplyToParenthesizedSubqueries,
                    AllowSingleJoin = shortQueriesAllowSingleJoin
                },
                Dml = new SqlDmlFormattingOptions
                {
                    UpdateSetStyle = updateSetStyle,
                    InsertColumnsStyle = insertColumnsStyle,
                    InsertValuesStyle = insertValuesStyle
                },
                Ddl = new SqlDdlFormattingOptions
                {
                    CreateProcLayout = createProcLayout
                },
                Comments = new SqlCommentsFormattingOptions
                {
                    PreserveAttachment = commentsPreserveAttachment,
                    Formatting = commentsFormatting
                }
            };

            var result = ModernMsSqlFormatter.TryFormat(sourceSql, options);
            if (!result.IsSuccess)
            {
                formattedSql = string.Empty;
                formattingError = result.ErrorMessage ?? "Parse failed.";
                return;
            }

            formattingError = null;
            formattedSql = result.FormattedSql ?? string.Empty;
        }
        catch (Exception ex)
        {
            formattedSql = string.Empty;
            formattingError = $"Unexpected formatter error: {ex.Message}";
        }
        finally
        {
            resizeEditorsPending = true;
        }
    }

    private IReadOnlyCollection<SqlInlineExpressionContext> BuildInlineShortExpressionContexts()
    {
        var contexts = new List<SqlInlineExpressionContext>();
        if (inlineShortContextSelectItem)
        {
            contexts.Add(SqlInlineExpressionContext.SelectItem);
        }

        if (inlineShortContextOn)
        {
            contexts.Add(SqlInlineExpressionContext.On);
        }

        if (inlineShortContextWhere)
        {
            contexts.Add(SqlInlineExpressionContext.Where);
        }

        return contexts;
    }
}

