                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("preserve string literals")'>
                                            <SqlOptionLabel ForId="sql-preserve-string-literals" Text="Preserve string literals" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-preserve-string-literals"
