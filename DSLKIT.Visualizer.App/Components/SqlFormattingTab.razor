@using DSLKIT.GrammarExamples.MsSql
@using DSLKIT.GrammarExamples.MsSql.Formatting
@using Microsoft.JSInterop

<section class="dsl-sql-formatting-tab">
    <div class="dsl-sql-header-row">
        <div class="text-muted small">
            Keep the formatted result visible while you tune options or source input.
        </div>

        <div class="dsl-sql-header-actions">
            <button class="btn btn-primary btn-sm"
                    @onclick="OnFormatRequestedAsync"
                    disabled="@isFormatterInitializing">
                Format SQL
            </button>
        </div>
    </div>

    @if (isFormatterInitializing)
    {
        <div class="alert alert-info py-2 mb-3" role="status">
            Loading SQL grammar and initializing formatter. First startup may take several seconds.
        </div>
    }

    <section class="card dsl-sql-source-panel">
        <details class="dsl-sql-source-details" open>
            <summary class="dsl-sql-source-summary">
                <span class="dsl-sql-source-title">Source SQL</span>
                <span class="dsl-sql-source-preview">@GetSourcePreview()</span>
            </summary>

            <div class="dsl-sql-source-body">
                <div class="dsl-sql-source-toolbar">
                    <label class="dsl-sql-autoformat-toggle" for="sql-auto-format">
                        <input id="sql-auto-format" class="form-check-input mt-0" type="checkbox" @bind="autoFormat" disabled="@isFormatterInitializing" />
                        <span>Auto-format input</span>
                    </label>
                    <label class="dsl-sql-autoformat-toggle" for="sql-auto-format-options">
                        <input id="sql-auto-format-options" class="form-check-input mt-0" type="checkbox" @bind="autoFormatOptions" disabled="@isFormatterInitializing" />
                        <span>Auto-format on option change</span>
                    </label>

                    <div class="dsl-sql-input-actions">
                        <button class="btn btn-outline-secondary btn-sm"
                                @onclick="OnLoadDemoRequestedAsync"
                                disabled="@isFormatterInitializing">
                            Load Demo SQL
                        </button>
                    </div>
                </div>

                <textarea id="sql-source-input"
                          class="form-control dsl-sql-editor dsl-sql-source-editor"
                          spellcheck="false"
                          value="@sourceSql"
                          disabled="@isFormatterInitializing"
                          @oninput="OnSourceInputAsync"></textarea>
            </div>
        </details>
    </section>

    <fieldset class="m-0 p-0 border-0 dsl-sql-workspace" disabled="@isFormatterInitializing">
        <MudSplitPanel Class="dsl-sql-workspace-split"
                       FirstPanelInitialSize="420"
                       MinPanelSize="290"
                       PanelGap="10">
        <FirstPanel>
            <div class="dsl-sql-workspace-panel">
                <section class="card dsl-sql-controls-panel">
                    <div class="card-header dsl-sql-controls-header">
                        <span>Options</span>
                    </div>

                    <div class="card-body dsl-sql-controls-body">
                            <div class="dsl-sql-search">
                                <input id="sql-option-search"
                                       type="search"
                                       class="form-control form-control-sm"
                                       placeholder="Search option..."
                                       @bind="optionSearch"
                                       @bind:event="oninput" />
                            </div>

                            <CascadingValue Value="OptionExamples">
                                <div class="dsl-sql-option-sections" @onchange="OnOptionsChangedAsync">
                                <details class="dsl-sql-option-section" open>
                                    <summary>General</summary>
                                    <div class="dsl-sql-property-grid">
                                        <div class="dsl-sql-property-row" hidden='@HideOption("keyword keyword case uppercase lowercase preserve")'>
                                            <SqlOptionLabel ForId="sql-keyword-case" Text="Keyword case" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-keyword-case" class="form-select form-select-sm" @bind="keywordCase" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlKeywordCase.Upper">Upper</option>
                                                <option value="@SqlKeywordCase.Lower">Lower</option>
                                                <option value="@SqlKeywordCase.Preserve">Preserve</option>
                                            </select>
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("statement semicolon terminate with semicolon")'>
                                            <SqlOptionLabel ForId="sql-statement-semicolon" Text="Terminate with semicolon" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-statement-semicolon" class="form-select form-select-sm" @bind="terminateWithSemicolon" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlStatementTerminationMode.Never">Never</option>
                                                <option value="@SqlStatementTerminationMode.ExistingOnly">Existing only</option>
                                                <option value="@SqlStatementTerminationMode.Always">Always</option>
                                            </select>
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("end of file eof newline new line")'>
                                            <SqlOptionLabel ForId="sql-eof-newline" Text="EOF newline" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-eof-newline" class="form-check-input" type="checkbox" @bind="eofNewline" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                    </div>
                                </details>

                                <details class="dsl-sql-option-section" open>
                                    <summary>Layout</summary>
                                    <div class="dsl-sql-property-grid">
                                        <div class="dsl-sql-property-row" hidden='@HideOption("layout indent indent size")'>
                                            <SqlOptionLabel ForId="sql-indent-size" Text="Indent size" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-indent-size"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="1"
                                                   step="1"
                                                   @bind="indentSize" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("layout blank line between clauses")'>
                                            <SqlOptionLabel ForId="sql-blank-line-between-clauses" Text="Blank line between clauses" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-blank-line-between-clauses"
                                                   class="form-check-input"
                                                   type="checkbox"
                                                   @bind="blankLineBetweenClauses" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("layout newline with")'>
                                            <SqlOptionLabel ForId="sql-newline-with" Text="New line before WITH" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-newline-with" class="form-check-input" type="checkbox" @bind="newlineBeforeWith" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("layout newline select")'>
                                            <SqlOptionLabel ForId="sql-newline-select" Text="New line before SELECT" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-newline-select" class="form-check-input" type="checkbox" @bind="newlineBeforeSelect" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("layout newline from")'>
                                            <SqlOptionLabel ForId="sql-newline-from" Text="New line before FROM" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-newline-from" class="form-check-input" type="checkbox" @bind="newlineBeforeFrom" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("layout newline where")'>
                                            <SqlOptionLabel ForId="sql-newline-where" Text="New line before WHERE" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-newline-where" class="form-check-input" type="checkbox" @bind="newlineBeforeWhere" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("layout newline group by")'>
                                            <SqlOptionLabel ForId="sql-newline-group-by" Text="New line before GROUP BY" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-newline-group-by" class="form-check-input" type="checkbox" @bind="newlineBeforeGroupBy" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("layout newline having")'>
                                            <SqlOptionLabel ForId="sql-newline-having" Text="New line before HAVING" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-newline-having" class="form-check-input" type="checkbox" @bind="newlineBeforeHaving" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("layout newline order by")'>
                                            <SqlOptionLabel ForId="sql-newline-order-by" Text="New line before ORDER BY" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-newline-order-by" class="form-check-input" type="checkbox" @bind="newlineBeforeOrderBy" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("layout newline option")'>
                                            <SqlOptionLabel ForId="sql-newline-option" Text="New line before OPTION" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-newline-option" class="form-check-input" type="checkbox" @bind="newlineBeforeOption" @bind:after="OnOptionValueChangedAsync" />
                                        </div>
                                    </div>
                                </details>

                                <details class="dsl-sql-option-section" open>
                                    <summary>Joins</summary>
                                    <div class="dsl-sql-property-grid">
                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("joins newline per join")'>
                                            <SqlOptionLabel ForId="sql-joins-newline-per-join" Text="New line per JOIN" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-joins-newline-per-join" class="form-check-input" type="checkbox" @bind="joinsNewlinePerJoin" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("joins on new line")'>
                                            <SqlOptionLabel ForId="sql-joins-on-new-line" Text="ON on new line" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-joins-on-new-line" class="form-check-input" type="checkbox" @bind="joinsOnNewLine" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("joins multiline on threshold max tokens single line")'>
                                            <SqlOptionLabel ForId="sql-joins-multiline-threshold" Text="ON max tokens single line" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-joins-multiline-threshold"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="0"
                                                   step="1"
                                                   @bind="joinsMultilineOnMaxTokensSingleLine" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("joins multiline on threshold break on and")'>
                                            <SqlOptionLabel ForId="sql-joins-break-on-and" Text="ON break on AND" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-joins-break-on-and" class="form-check-input" type="checkbox" @bind="joinsMultilineOnBreakOnAnd" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("joins multiline on threshold break on or")'>
                                            <SqlOptionLabel ForId="sql-joins-break-on-or" Text="ON break on OR" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-joins-break-on-or" class="form-check-input" type="checkbox" @bind="joinsMultilineOnBreakOnOr" @bind:after="OnOptionValueChangedAsync" />
                                        </div>
                                    </div>
                                </details>

                                <details class="dsl-sql-option-section" open>
                                    <summary>Predicates</summary>
                                    <div class="dsl-sql-property-grid">
                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("predicates multiline where having")'>
                                            <SqlOptionLabel ForId="sql-predicates-multiline-where" Text="Multiline WHERE/HAVING" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-predicates-multiline-where" class="form-check-input" type="checkbox" @bind="predicatesMultilineWhere" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("predicates logical operator line break before after")'>
                                            <SqlOptionLabel ForId="sql-predicates-logical-break" Text="Logical operator break" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-predicates-logical-break"
                                                    class="form-select form-select-sm"
                                                    @bind="predicatesLogicalOperatorLineBreak" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlLogicalOperatorLineBreakMode.BeforeOperator">Before operator</option>
                                                <option value="@SqlLogicalOperatorLineBreakMode.AfterOperator">After operator</option>
                                            </select>
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("predicates inline simple predicate max conditions")'>
                                            <SqlOptionLabel ForId="sql-predicates-inline-max-conditions" Text="Inline max conditions" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-predicates-inline-max-conditions"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="0"
                                                   step="1"
                                                   @bind="predicatesInlineSimpleMaxConditions" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("predicates inline simple predicate max line length")'>
                                            <SqlOptionLabel ForId="sql-predicates-inline-max-line-length" Text="Inline max line length" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-predicates-inline-max-line-length"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="10"
                                                   step="1"
                                                   @bind="predicatesInlineSimpleMaxLineLength" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("predicates inline simple predicate allow only and")'>
                                            <SqlOptionLabel ForId="sql-predicates-inline-allow-only-and" Text="Inline allow only AND" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-predicates-inline-allow-only-and" class="form-check-input" type="checkbox" @bind="predicatesInlineSimpleAllowOnlyAnd" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("predicates mixed and or parenthesize or groups")'>
                                            <SqlOptionLabel ForId="sql-predicates-mixed-and-or-parenthesize-or-groups" Text="Parenthesize OR groups" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-predicates-mixed-and-or-parenthesize-or-groups"
                                                   class="form-check-input"
                                                   type="checkbox"
                                                   @bind="predicatesMixedAndOrParenthesizeOrGroups" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("predicates mixed and or break or groups")'>
                                            <SqlOptionLabel ForId="sql-predicates-mixed-and-or-break-or-groups" Text="Break OR groups" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-predicates-mixed-and-or-break-or-groups"
                                                   class="form-check-input"
                                                   type="checkbox"
                                                   @bind="predicatesMixedAndOrBreakOrGroups" @bind:after="OnOptionValueChangedAsync" />
                                        </div>
                                    </div>
                                </details>

                                <details class="dsl-sql-option-section" open>
                                    <summary>Expressions</summary>
                                    <div class="dsl-sql-property-grid">
                                        <div class="dsl-sql-property-row" hidden='@HideOption("expressions case style multiline compact when short")'>
                                            <SqlOptionLabel ForId="sql-expressions-case-style" Text="CASE style" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-expressions-case-style"
                                                    class="form-select form-select-sm"
                                                    @bind="expressionsCaseStyle" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlCaseStyle.Multiline">Multiline</option>
                                                <option value="@SqlCaseStyle.CompactWhenShort">Compact when short</option>
                                            </select>
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("expressions compact case threshold max when clauses")'>
                                            <SqlOptionLabel ForId="sql-case-threshold-max-when" Text="CASE max WHEN clauses" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-case-threshold-max-when"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="0"
                                                   step="1"
                                                   @bind="compactCaseMaxWhenClauses" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("expressions compact case threshold max tokens")'>
                                            <SqlOptionLabel ForId="sql-case-threshold-max-tokens" Text="CASE max tokens" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-case-threshold-max-tokens"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="0"
                                                   step="1"
                                                   @bind="compactCaseMaxTokens" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("expressions compact case threshold max line length")'>
                                            <SqlOptionLabel ForId="sql-case-threshold-max-line" Text="CASE max line length" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-case-threshold-max-line"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="10"
                                                   step="1"
                                                   @bind="compactCaseMaxLineLength" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("expressions inline short expression max tokens")'>
                                            <SqlOptionLabel ForId="sql-inline-short-max-tokens" Text="Inline short max tokens" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-inline-short-max-tokens"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="0"
                                                   step="1"
                                                   @bind="inlineShortExpressionMaxTokens" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("expressions inline short expression max depth")'>
                                            <SqlOptionLabel ForId="sql-inline-short-max-depth" Text="Inline short max depth" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-inline-short-max-depth"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="0"
                                                   step="1"
                                                   @bind="inlineShortExpressionMaxDepth" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("expressions inline short expression max line length")'>
                                            <SqlOptionLabel ForId="sql-inline-short-max-line" Text="Inline short max line" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-inline-short-max-line"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="10"
                                                   step="1"
                                                   @bind="inlineShortExpressionMaxLineLength" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("expressions inline short expression context select item")'>
                                            <SqlOptionLabel ForId="sql-inline-short-select-item" Text="Inline in SELECT items" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-inline-short-select-item" class="form-check-input" type="checkbox" @bind="inlineShortContextSelectItem" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("expressions inline short expression context on")'>
                                            <SqlOptionLabel ForId="sql-inline-short-on" Text="Inline in ON" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-inline-short-on" class="form-check-input" type="checkbox" @bind="inlineShortContextOn" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("expressions inline short expression context where")'>
                                            <SqlOptionLabel ForId="sql-inline-short-where" Text="Inline in WHERE" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-inline-short-where" class="form-check-input" type="checkbox" @bind="inlineShortContextWhere" @bind:after="OnOptionValueChangedAsync" />
                                        </div>
                                    </div>
                                </details>

                                <details class="dsl-sql-option-section" open>
                                    <summary>Lists</summary>
                                    <div class="dsl-sql-property-grid">
                                        <div class="dsl-sql-property-row" hidden='@HideOption("lists comma style trailing leading")'>
                                            <SqlOptionLabel ForId="sql-comma-style" Text="Comma style" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-comma-style" class="form-select form-select-sm" @bind="commaStyle" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlCommaStyle.Trailing">Trailing</option>
                                                <option value="@SqlCommaStyle.Leading">Leading</option>
                                            </select>
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("lists select items style")'>
                                            <SqlOptionLabel ForId="sql-select-items-style" Text="SELECT items" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-select-items-style" class="form-select form-select-sm" @bind="selectItemsStyle" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlListLayoutStyle.OnePerLine">One per line</option>
                                                <option value="@SqlListLayoutStyle.WrapByWidth">Wrap by width</option>
                                            </select>
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("lists group by items style")'>
                                            <SqlOptionLabel ForId="sql-group-by-items-style" Text="GROUP BY items" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-group-by-items-style" class="form-select form-select-sm" @bind="groupByItemsStyle" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlListLayoutStyle.OnePerLine">One per line</option>
                                                <option value="@SqlListLayoutStyle.WrapByWidth">Wrap by width</option>
                                            </select>
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("lists order by items style")'>
                                            <SqlOptionLabel ForId="sql-order-by-items-style" Text="ORDER BY items" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-order-by-items-style" class="form-select form-select-sm" @bind="orderByItemsStyle" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlListLayoutStyle.OnePerLine">One per line</option>
                                                <option value="@SqlListLayoutStyle.WrapByWidth">Wrap by width</option>
                                            </select>
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("lists select compact threshold max items")'>
                                            <SqlOptionLabel ForId="sql-select-compact-max-items" Text="Compact max items" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-select-compact-max-items"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="0"
                                                   step="1"
                                                   @bind="selectCompactMaxItems" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("lists select compact threshold max line length")'>
                                            <SqlOptionLabel ForId="sql-select-compact-max-line-length" Text="Compact max line length" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-select-compact-max-line-length"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="10"
                                                   step="1"
                                                   @bind="selectCompactMaxLineLength" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("lists compact threshold allow expressions")'>
                                            <SqlOptionLabel ForId="sql-select-compact-allow-expressions" Text="Compact allow expressions" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-select-compact-allow-expressions" class="form-check-input" type="checkbox" @bind="selectCompactAllowExpressions" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("align select aliases")'>
                                            <SqlOptionLabel ForId="sql-align-select-aliases" Text="Align select aliases" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-align-select-aliases" class="form-check-input" type="checkbox" @bind="alignSelectAliases" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

