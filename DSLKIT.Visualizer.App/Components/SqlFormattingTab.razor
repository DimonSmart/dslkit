@using DSLKIT.GrammarExamples.MsSql
@using DSLKIT.GrammarExamples.MsSql.Formatting
@using DSLKIT.Visualizer.App.Components.SqlFormatting
@using Microsoft.JSInterop

<section class="dsl-sql-formatting-tab">
    <div class="dsl-sql-header-row">
        <div class="text-muted small">
            Keep the formatted result visible while you tune options or source input.
        </div>

        <div class="dsl-sql-header-actions">
            <button class="btn btn-primary btn-sm"
                    @onclick="OnFormatRequestedAsync"
                    disabled="@state.IsFormatterInitializing">
                Format SQL
            </button>
        </div>
    </div>

    @if (state.IsFormatterInitializing)
    {
        <div class="alert alert-info py-2 mb-3" role="status">
            Loading SQL grammar and initializing formatter. First startup may take several seconds.
        </div>
    }

    <section class="card dsl-sql-source-panel">
        <details class="dsl-sql-source-details" open>
            <summary class="dsl-sql-source-summary">
                <span class="dsl-sql-source-title">Source SQL</span>
                <span class="dsl-sql-source-preview">@GetSourcePreview()</span>
            </summary>

            <div class="dsl-sql-source-body">
                <div class="dsl-sql-source-toolbar">
                    <label class="dsl-sql-autoformat-toggle" for="sql-auto-format">
                        <input id="sql-auto-format" class="form-check-input mt-0" type="checkbox" @bind="state.AutoFormat" disabled="@state.IsFormatterInitializing" />
                        <span>Auto-format input</span>
                    </label>
                    <label class="dsl-sql-autoformat-toggle" for="sql-auto-format-options">
                        <input id="sql-auto-format-options" class="form-check-input mt-0" type="checkbox" @bind="state.AutoFormatOptions" disabled="@state.IsFormatterInitializing" />
                        <span>Auto-format on option change</span>
                    </label>

                    <div class="dsl-sql-input-actions">
                        <button class="btn btn-outline-secondary btn-sm"
                                @onclick="OnLoadDemoRequestedAsync"
                                disabled="@state.IsFormatterInitializing">
                            Load Demo SQL
                        </button>
                    </div>
                </div>

                <textarea id="sql-source-input"
                          class="form-control dsl-sql-editor dsl-sql-source-editor"
                          spellcheck="false"
                          value="@state.SourceSql"
                          disabled="@state.IsFormatterInitializing"
                          @oninput="OnSourceInputAsync"></textarea>
            </div>
        </details>
    </section>

    <fieldset class="m-0 p-0 border-0 dsl-sql-workspace" disabled="@state.IsFormatterInitializing">
        <MudSplitPanel Class="dsl-sql-workspace-split"
                       FirstPanelInitialSize="420"
                       MinPanelSize="290"
                       PanelGap="10">
        <FirstPanel>
            <div class="dsl-sql-workspace-panel">
                <section class="card dsl-sql-controls-panel">
                    <div class="card-header dsl-sql-controls-header">
                        <span>Options</span>
                    </div>

                    <div class="card-body dsl-sql-controls-body">
                            <div class="dsl-sql-search">
                                <input id="sql-option-search"
                                       type="search"
                                       class="form-control form-control-sm"
                                       placeholder="Search option..."
                                       @bind="state.OptionSearch"
                                       @bind:event="oninput" />
                            </div>

                                <div class="dsl-sql-option-sections" @onchange="OnOptionsChangedAsync">
                                <details class="dsl-sql-option-section" open>
                                    <summary>General</summary>
                                    <div class="dsl-sql-property-grid">
                                        <div class="dsl-sql-property-row" hidden='@HideOption("keyword keyword case uppercase lowercase preserve")'>
                                            <SqlOptionLabel ForId="sql-keyword-case" Text="Keyword case" ExampleSql="@SqlFormattingExamples.KeywordCaseExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-keyword-case" class="form-select form-select-sm" @bind="state.KeywordCase" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlKeywordCase.Upper">Upper</option>
                                                <option value="@SqlKeywordCase.Lower">Lower</option>
                                                <option value="@SqlKeywordCase.Preserve">Preserve</option>
                                            </select>
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("statement semicolon terminate with semicolon")'>
                                            <SqlOptionLabel ForId="sql-statement-semicolon" Text="Terminate with semicolon" ExampleSql="@SqlFormattingExamples.SemicolonAndEofExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-statement-semicolon" class="form-select form-select-sm" @bind="state.TerminateWithSemicolon" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlStatementTerminationMode.Never">Never</option>
                                                <option value="@SqlStatementTerminationMode.ExistingOnly">Existing only</option>
                                                <option value="@SqlStatementTerminationMode.Always">Always</option>
                                            </select>
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("end of file eof newline new line")'>
                                            <SqlOptionLabel ForId="sql-eof-newline" Text="EOF newline" ExampleSql="@SqlFormattingExamples.SemicolonAndEofExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-eof-newline" class="form-check-input" type="checkbox" @bind="state.EofNewline" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                    </div>
                                </details>

                                <details class="dsl-sql-option-section" open>
                                    <summary>Layout</summary>
                                    <div class="dsl-sql-property-grid">
                                        <div class="dsl-sql-property-row" hidden='@HideOption("layout indent indent size")'>
                                            <SqlOptionLabel ForId="sql-indent-size" Text="Indent size" ExampleSql="@SqlFormattingExamples.LayoutClausesExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-indent-size"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="1"
                                                   step="1"
                                                  @bind="state.IndentSize" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("layout wrap column wrap width wrap by width")'>
                                            <SqlOptionLabel ForId="sql-wrap-column" Text="Wrap width for wrap-by-width layouts" ExampleSql="@SqlFormattingExamples.ListsExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-wrap-column"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="10"
                                                   step="1"
                                                  @bind="state.WrapColumn" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("layout blank line between clauses")'>
                                            <SqlOptionLabel ForId="sql-blank-line-between-clauses" Text="Blank line between clauses" ExampleSql="@SqlFormattingExamples.LayoutClausesExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-blank-line-between-clauses"
                                                   class="form-check-input"
                                                   type="checkbox"
                                                   @bind="state.BlankLineBetweenClauses" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("layout newline with")'>
                                            <SqlOptionLabel ForId="sql-newline-with" Text="New line before WITH" ExampleSql="@SqlFormattingExamples.LayoutWithClauseExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-newline-with" class="form-check-input" type="checkbox" @bind="state.NewlineBeforeWith" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("layout newline select")'>
                                            <SqlOptionLabel ForId="sql-newline-select" Text="New line before SELECT" ExampleSql="@SqlFormattingExamples.LayoutClausesExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-newline-select" class="form-check-input" type="checkbox" @bind="state.NewlineBeforeSelect" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("layout newline from")'>
                                            <SqlOptionLabel ForId="sql-newline-from" Text="New line before FROM" ExampleSql="@SqlFormattingExamples.LayoutClausesExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-newline-from" class="form-check-input" type="checkbox" @bind="state.NewlineBeforeFrom" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("layout newline where")'>
                                            <SqlOptionLabel ForId="sql-newline-where" Text="New line before WHERE" ExampleSql="@SqlFormattingExamples.LayoutClausesExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-newline-where" class="form-check-input" type="checkbox" @bind="state.NewlineBeforeWhere" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("layout newline group by")'>
                                            <SqlOptionLabel ForId="sql-newline-group-by" Text="New line before GROUP BY" ExampleSql="@SqlFormattingExamples.LayoutClausesExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-newline-group-by" class="form-check-input" type="checkbox" @bind="state.NewlineBeforeGroupBy" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("layout newline having")'>
                                            <SqlOptionLabel ForId="sql-newline-having" Text="New line before HAVING" ExampleSql="@SqlFormattingExamples.LayoutClausesExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-newline-having" class="form-check-input" type="checkbox" @bind="state.NewlineBeforeHaving" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("layout newline order by")'>
                                            <SqlOptionLabel ForId="sql-newline-order-by" Text="New line before ORDER BY" ExampleSql="@SqlFormattingExamples.LayoutClausesExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-newline-order-by" class="form-check-input" type="checkbox" @bind="state.NewlineBeforeOrderBy" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("layout newline option")'>
                                            <SqlOptionLabel ForId="sql-newline-option" Text="New line before OPTION" ExampleSql="@SqlFormattingExamples.LayoutOptionClauseExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-newline-option" class="form-check-input" type="checkbox" @bind="state.NewlineBeforeOption" @bind:after="OnOptionValueChangedAsync" />
                                        </div>
                                    </div>
                                </details>

                                <details class="dsl-sql-option-section" open>
                                    <summary>Joins</summary>
                                    <div class="dsl-sql-property-grid">
                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("joins newline per join")'>
                                            <SqlOptionLabel ForId="sql-joins-newline-per-join" Text="New line per JOIN" ExampleSql="@SqlFormattingExamples.JoinsExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-joins-newline-per-join" class="form-check-input" type="checkbox" @bind="state.JoinsNewlinePerJoin" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("joins on new line")'>
                                            <SqlOptionLabel ForId="sql-joins-on-new-line" Text="ON on new line" ExampleSql="@SqlFormattingExamples.JoinsExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-joins-on-new-line" class="form-check-input" type="checkbox" @bind="state.JoinsOnNewLine" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("joins multiline on threshold max tokens single line split on tokens exceed")'>
                                            <SqlOptionLabel ForId="sql-joins-multiline-threshold" Text="Split ON when tokens exceed" ExampleSql="@SqlFormattingExamples.JoinsExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-joins-multiline-threshold"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="0"
                                                   step="1"
                                                   @bind="state.JoinsMultilineOnMaxTokensSingleLine" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: !state.AreJoinBreakOptionsEnabled, isCheck: true)" hidden='@HideOption("joins multiline on threshold break on and")'>
                                            <SqlOptionLabel ForId="sql-joins-break-on-and" Text="ON break on AND" ExampleSql="@SqlFormattingExamples.JoinsExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-joins-break-on-and" class="form-check-input" type="checkbox" disabled="@(!state.AreJoinBreakOptionsEnabled)" @bind="state.JoinsMultilineOnBreakOnAnd" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: !state.AreJoinBreakOptionsEnabled, isCheck: true)" hidden='@HideOption("joins multiline on threshold break on or")'>
                                            <SqlOptionLabel ForId="sql-joins-break-on-or" Text="ON break on OR" ExampleSql="@SqlFormattingExamples.JoinsExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-joins-break-on-or" class="form-check-input" type="checkbox" disabled="@(!state.AreJoinBreakOptionsEnabled)" @bind="state.JoinsMultilineOnBreakOnOr" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-note text-muted small">
                                            Break options are active when the <code>ON</code> token threshold is greater than <code>0</code>.
                                        </div>
                                    </div>
                                </details>

                                <details class="dsl-sql-option-section" open>
                                    <summary>Predicates</summary>
                                    <div class="dsl-sql-property-grid">
                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("predicates multiline where having")'>
                                            <SqlOptionLabel ForId="sql-predicates-multiline-where" Text="Multiline WHERE/HAVING" ExampleSql="@SqlFormattingExamples.PredicatesExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-predicates-multiline-where" class="form-check-input" type="checkbox" @bind="state.PredicatesMultilineWhere" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-note text-muted small">
                                            Multiline predicate layout
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: !state.ArePredicateMultilineLayoutSettingsEnabled)" hidden='@HideOption("predicates logical operator line break before after")'>
                                            <SqlOptionLabel ForId="sql-predicates-logical-break" Text="Logical operator break" ExampleSql="@SqlFormattingExamples.PredicatesExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-predicates-logical-break"
                                                    class="form-select form-select-sm"
                                                    disabled="@(!state.ArePredicateMultilineLayoutSettingsEnabled)"
                                                    @bind="state.PredicatesLogicalOperatorLineBreak" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlLogicalOperatorLineBreakMode.BeforeOperator">Before operator</option>
                                                <option value="@SqlLogicalOperatorLineBreakMode.AfterOperator">After operator</option>
                                            </select>
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: !state.ArePredicateInlineSettingsEnabled)" hidden='@HideOption("predicates inline simple predicate max conditions")'>
                                            <SqlOptionLabel ForId="sql-predicates-inline-max-conditions" Text="Inline max conditions" ExampleSql="@SqlFormattingExamples.PredicatesInlineExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-predicates-inline-max-conditions"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="0"
                                                   step="1"
                                                   disabled="@(!state.ArePredicateInlineSettingsEnabled)"
                                                   @bind="state.PredicatesInlineSimpleMaxConditions" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: !state.ArePredicateInlineSecondarySettingsEnabled)" hidden='@HideOption("predicates inline simple predicate max line length")'>
                                            <SqlOptionLabel ForId="sql-predicates-inline-max-line-length" Text="Inline max line length" ExampleSql="@SqlFormattingExamples.PredicatesInlineExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-predicates-inline-max-line-length"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="10"
                                                   step="1"
                                                   disabled="@(!state.ArePredicateInlineSecondarySettingsEnabled)"
                                                   @bind="state.PredicatesInlineSimpleMaxLineLength" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: !state.ArePredicateInlineSecondarySettingsEnabled, isCheck: true)" hidden='@HideOption("predicates inline simple predicate allow only and")'>
                                            <SqlOptionLabel ForId="sql-predicates-inline-allow-only-and" Text="Inline allow only AND" ExampleSql="@SqlFormattingExamples.PredicateAllowOnlyAndExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-predicates-inline-allow-only-and" class="form-check-input" type="checkbox" disabled="@(!state.ArePredicateInlineSecondarySettingsEnabled)" @bind="state.PredicatesInlineSimpleAllowOnlyAnd" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-note text-muted small">
                                            Inline predicate settings are active when <code>Multiline WHERE/HAVING</code> is enabled. Line length and AND-only rules also require <code>Inline max conditions</code> to be greater than <code>0</code>.
                                        </div>

                                        <div class="dsl-sql-property-note text-muted small">
                                            Mixed AND/OR handling
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("predicates mixed and or parenthesize or groups")'>
                                            <SqlOptionLabel ForId="sql-predicates-mixed-and-or-parenthesize-or-groups" Text="Parenthesize OR groups" ExampleSql="@SqlFormattingExamples.PredicatesExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-predicates-mixed-and-or-parenthesize-or-groups"
                                                   class="form-check-input"
                                                   type="checkbox"
                                                   @bind="state.PredicatesMixedAndOrParenthesizeOrGroups" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: !state.ArePredicateMultilineLayoutSettingsEnabled, isCheck: true)" hidden='@HideOption("predicates mixed and or break or groups")'>
                                            <SqlOptionLabel ForId="sql-predicates-mixed-and-or-break-or-groups" Text="Break OR groups" ExampleSql="@SqlFormattingExamples.PredicatesExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-predicates-mixed-and-or-break-or-groups"
                                                   class="form-check-input"
                                                   type="checkbox"
                                                   disabled="@(!state.ArePredicateMultilineLayoutSettingsEnabled)"
                                                   @bind="state.PredicatesMixedAndOrBreakOrGroups" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-note text-muted small">
                                            <code>Logical operator break</code> and <code>Break OR groups</code> are active only when <code>Multiline WHERE/HAVING</code> is enabled. <code>Parenthesize OR groups</code> also affects inline predicates.
                                        </div>
                                    </div>
                                </details>

                                <details class="dsl-sql-option-section" open>
                                    <summary>Short Queries</summary>
                                    <div class="dsl-sql-property-grid">
                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("short queries keep inline compact enabled short query")'>
                                            <SqlOptionLabel ForId="sql-short-queries-enabled" Text="Keep short queries inline" ExampleSql="@SqlFormattingExamples.ShortQueriesExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-short-queries-enabled" class="form-check-input" type="checkbox" @bind="state.ShortQueriesEnabled" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: !state.ShortQueriesEnabled)" hidden='@HideOption("short queries max line length short query")'>
                                            <SqlOptionLabel ForId="sql-short-queries-max-line-length" Text="Short query max line length" ExampleSql="@SqlFormattingExamples.ShortQueriesExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-short-queries-max-line-length"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="10"
                                                   step="1"
                                                   disabled="@(!state.ShortQueriesEnabled)"
                                                   @bind="state.ShortQueriesMaxLineLength" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: !state.ShortQueriesEnabled)" hidden='@HideOption("short queries max select items short query")'>
                                            <SqlOptionLabel ForId="sql-short-queries-max-select-items" Text="Short query max SELECT items" ExampleSql="@SqlFormattingExamples.ShortQuerySelectItemsExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-short-queries-max-select-items"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="1"
                                                   step="1"
                                                   disabled="@(!state.ShortQueriesEnabled)"
                                                   @bind="state.ShortQueriesMaxSelectItems" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: !state.ShortQueriesEnabled)" hidden='@HideOption("short queries max where conditions predicate conditions")'>
                                            <SqlOptionLabel ForId="sql-short-queries-max-predicate-conditions" Text="Short query max WHERE conditions" ExampleSql="@SqlFormattingExamples.ShortQueryPredicateThresholdExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-short-queries-max-predicate-conditions"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="1"
                                                   step="1"
                                                   disabled="@(!state.ShortQueriesEnabled)"
                                                   @bind="state.ShortQueriesMaxPredicateConditions" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: !state.ShortQueriesEnabled, isCheck: true)" hidden='@HideOption("short queries apply to parenthesized subqueries")'>
                                            <SqlOptionLabel ForId="sql-short-queries-apply-to-parenthesized-subqueries" Text="Apply to parenthesized subqueries" ExampleSql="@SqlFormattingExamples.ShortQueriesExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-short-queries-apply-to-parenthesized-subqueries" class="form-check-input" type="checkbox" disabled="@(!state.ShortQueriesEnabled)" @bind="state.ShortQueriesApplyToParenthesizedSubqueries" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: !state.ShortQueriesEnabled, isCheck: true)" hidden='@HideOption("short queries allow single join")'>
                                            <SqlOptionLabel ForId="sql-short-queries-allow-single-join" Text="Allow single JOIN" ExampleSql="@SqlFormattingExamples.ShortQueriesExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-short-queries-allow-single-join" class="form-check-input" type="checkbox" disabled="@(!state.ShortQueriesEnabled)" @bind="state.ShortQueriesAllowSingleJoin" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-note text-muted small">
                                            Short query thresholds are active when <code>Keep short queries inline</code> is enabled.
                                        </div>
                                    </div>
                                </details>

                                <details class="dsl-sql-option-section" open>
                                    <summary>CASE</summary>
                                    <div class="dsl-sql-property-grid">
                                        <div class="dsl-sql-property-row" hidden='@HideOption("expressions case style multiline compact when short")'>
                                            <SqlOptionLabel ForId="sql-expressions-case-style" Text="CASE style" ExampleSql="@SqlFormattingExamples.ExpressionsCaseExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                                <select id="sql-expressions-case-style"
                                                    class="form-select form-select-sm"
                                                    @bind="state.ExpressionsCaseStyle" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlCaseStyle.Multiline">Multiline</option>
                                                <option value="@SqlCaseStyle.CompactWhenShort">Compact when short</option>
                                            </select>
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: !state.AreCompactCaseThresholdsEnabled)" hidden='@HideOption("expressions compact case threshold max when clauses")'>
                                            <SqlOptionLabel ForId="sql-case-threshold-max-when" Text="CASE max WHEN clauses" ExampleSql="@SqlFormattingExamples.ExpressionsCaseExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-case-threshold-max-when"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="0"
                                                   step="1"
                                                   disabled="@(!state.AreCompactCaseThresholdsEnabled)"
                                                   @bind="state.CompactCaseMaxWhenClauses" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: !state.AreCompactCaseThresholdsEnabled)" hidden='@HideOption("expressions compact case threshold max line length")'>
                                            <SqlOptionLabel ForId="sql-case-threshold-max-line" Text="CASE max line length" ExampleSql="@SqlFormattingExamples.ExpressionsCaseExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-case-threshold-max-line"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="10"
                                                   step="1"
                                                   disabled="@(!state.AreCompactCaseThresholdsEnabled)"
                                                   @bind="state.CompactCaseMaxLineLength" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-note text-muted small">
                                            CASE thresholds are active when <code>Compact when short</code> is selected.
                                        </div>
                                    </div>
                                </details>

                                <details class="dsl-sql-option-section" open>
                                    <summary>Inline Expressions</summary>
                                    <div class="dsl-sql-property-grid">
                                        <div class="dsl-sql-property-note text-muted small">
                                            Thresholds
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("expressions inline short expression max tokens")'>
                                            <SqlOptionLabel ForId="sql-inline-short-max-tokens" Text="Inline short expressions max tokens" ExampleSql="@SqlFormattingExamples.InlineShortExpressionExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-inline-short-max-tokens"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="0"
                                                   step="1"
                                                   @bind="state.InlineShortExpressionMaxTokens" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: !state.AreInlineShortSecondarySettingsEnabled)" hidden='@HideOption("expressions inline short expression max line length")'>
                                            <SqlOptionLabel ForId="sql-inline-short-max-line" Text="Inline expression max line length" ExampleSql="@SqlFormattingExamples.InlineShortExpressionExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-inline-short-max-line"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="10"
                                                   step="1"
                                                   disabled="@(!state.AreInlineShortSecondarySettingsEnabled)"
                                                   @bind="state.InlineShortExpressionMaxLineLength" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-note text-muted small">
                                            Contexts
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: !state.AreInlineShortSecondarySettingsEnabled, isCheck: true)" hidden='@HideOption("expressions inline short expression context select item")'>
                                            <SqlOptionLabel ForId="sql-inline-short-select-item" Text="Inline SELECT item expressions" ExampleSql="@SqlFormattingExamples.InlineShortExpressionExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-inline-short-select-item" class="form-check-input" type="checkbox" disabled="@(!state.AreInlineShortSecondarySettingsEnabled)" @bind="state.InlineShortContextSelectItem" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: !state.AreInlineShortSecondarySettingsEnabled, isCheck: true)" hidden='@HideOption("expressions inline short expression context on")'>
                                            <SqlOptionLabel ForId="sql-inline-short-on" Text="Inline ON expressions" ExampleSql="@SqlFormattingExamples.InlineShortExpressionExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-inline-short-on" class="form-check-input" type="checkbox" disabled="@(!state.AreInlineShortSecondarySettingsEnabled)" @bind="state.InlineShortContextOn" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: !state.AreInlineShortSecondarySettingsEnabled, isCheck: true)" hidden='@HideOption("expressions inline short expression context where")'>
                                            <SqlOptionLabel ForId="sql-inline-short-where" Text="Inline WHERE expressions" ExampleSql="@SqlFormattingExamples.InlineShortExpressionExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-inline-short-where" class="form-check-input" type="checkbox" disabled="@(!state.AreInlineShortSecondarySettingsEnabled)" @bind="state.InlineShortContextWhere" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-note text-muted small">
                                            Inline expression line length is active when <code>Inline short expressions max tokens</code> is greater than <code>0</code>. Formatting also requires at least one context below to be enabled.
                                        </div>

                                        @if (state.AreInlineShortSecondarySettingsEnabled && !state.AreInlineShortContextsSelected)
                                        {
                                            <div class="dsl-sql-property-note text-muted small">
                                                Select at least one context below to activate inline short expressions on the example SQL.
                                            </div>
                                        }
                                    </div>
                                </details>

                                <details class="dsl-sql-option-section" open>
                                    <summary>Lists</summary>
                                    <div class="dsl-sql-property-grid">
                                        <div class="dsl-sql-property-row" hidden='@HideOption("lists comma style trailing leading")'>
                                            <SqlOptionLabel ForId="sql-comma-style" Text="Comma style" ExampleSql="@SqlFormattingExamples.ListsExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-comma-style" class="form-select form-select-sm" @bind="state.CommaStyle" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlCommaStyle.Trailing">Trailing</option>
                                                <option value="@SqlCommaStyle.Leading">Leading</option>
                                            </select>
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("lists select items style")'>
                                            <SqlOptionLabel ForId="sql-select-items-style" Text="SELECT items" ExampleSql="@SqlFormattingExamples.ListsExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-select-items-style" class="form-select form-select-sm" @bind="state.SelectItemsStyle" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlListLayoutStyle.OnePerLine">One per line</option>
                                                <option value="@SqlListLayoutStyle.WrapByWidth">Wrap by width</option>
                                            </select>
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("lists group by items style")'>
                                            <SqlOptionLabel ForId="sql-group-by-items-style" Text="GROUP BY items" ExampleSql="@SqlFormattingExamples.ListsExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-group-by-items-style" class="form-select form-select-sm" @bind="state.GroupByItemsStyle" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlListLayoutStyle.OnePerLine">One per line</option>
                                                <option value="@SqlListLayoutStyle.WrapByWidth">Wrap by width</option>
                                            </select>
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("lists order by items style")'>
                                            <SqlOptionLabel ForId="sql-order-by-items-style" Text="ORDER BY items" ExampleSql="@SqlFormattingExamples.ListsExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-order-by-items-style" class="form-select form-select-sm" @bind="state.OrderByItemsStyle" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlListLayoutStyle.OnePerLine">One per line</option>
                                                <option value="@SqlListLayoutStyle.WrapByWidth">Wrap by width</option>
                                            </select>
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("lists compact select list max items")'>
                                            <SqlOptionLabel ForId="sql-select-compact-max-items" Text="Compact SELECT list max items" ExampleSql="@SqlFormattingExamples.SelectCompactThresholdExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-select-compact-max-items"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="0"
                                                   step="1"
                                                   @bind="state.SelectCompactMaxItems" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("lists compact select list max line length")'>
                                            <SqlOptionLabel ForId="sql-select-compact-max-line-length" Text="Compact SELECT list max line length" ExampleSql="@SqlFormattingExamples.SelectCompactLineLengthExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-select-compact-max-line-length"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="10"
                                                   step="1"
                                                   @bind="state.SelectCompactMaxLineLength" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-note text-muted small">
                                            Applied after <code>SELECT items</code> decide to wrap, so a short list can still stay inline when it fits by item count and total line length.
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("align select aliases")'>
                                            <SqlOptionLabel ForId="sql-align-select-aliases" Text="Align select aliases" ExampleSql="@SqlFormattingExamples.AlignAliasesExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-align-select-aliases" class="form-check-input" type="checkbox" @bind="state.AlignSelectAliases" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("lists in list items style inline one per line wrap by width")'>
                                            <SqlOptionLabel ForId="sql-in-list-items-style" Text="IN list items" ExampleSql="@SqlFormattingExamples.ListsExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-in-list-items-style" class="form-select form-select-sm" @bind="state.InListItemsStyle" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlInListItemsStyle.Inline">Inline</option>
                                                <option value="@SqlInListItemsStyle.OnePerLine">One per line</option>
                                                <option value="@SqlInListItemsStyle.WrapByWidth">Wrap by width</option>
                                            </select>
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: state.InListItemsStyle == SqlInListItemsStyle.Inline)" hidden='@HideOption("lists inline in list threshold max items inline")'>
                                            <SqlOptionLabel ForId="sql-inline-in-list-max-items" Text="Inline IN max items" ExampleSql="@SqlFormattingExamples.InListThresholdExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-inline-in-list-max-items"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="0"
                                                   step="1"
                                                   disabled="@(state.InListItemsStyle == SqlInListItemsStyle.Inline)"
                                                   @bind="state.InlineInListMaxItems" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="@GetPropertyRowClass(disabled: state.InListItemsStyle == SqlInListItemsStyle.Inline)" hidden='@HideOption("lists inline in list threshold max line length")'>
                                            <SqlOptionLabel ForId="sql-inline-in-list-max-line" Text="Inline IN max line" ExampleSql="@SqlFormattingExamples.InListThresholdExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-inline-in-list-max-line"
                                                   class="form-control form-control-sm"
                                                   type="number"
                                                   min="10"
                                                   step="1"
                                                   disabled="@(state.InListItemsStyle == SqlInListItemsStyle.Inline)"
                                                   @bind="state.InlineInListMaxLineLength" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-note text-muted small">
                                            Active when <code>IN list items</code> uses <code>One per line</code> or <code>Wrap by width</code>.
                                        </div>
                                    </div>
                                </details>

                                <details class="dsl-sql-option-section" open>
                                    <summary>DML</summary>
                                    <div class="dsl-sql-property-grid">
                                        <div class="dsl-sql-property-row" hidden='@HideOption("dml update set style one per line wrap by width")'>
                                            <SqlOptionLabel ForId="sql-update-set-style" Text="UPDATE SET style" ExampleSql="@SqlFormattingExamples.DmlAndDdlExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-update-set-style" class="form-select form-select-sm" @bind="state.UpdateSetStyle" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlDmlListStyle.OnePerLine">One per line</option>
                                                <option value="@SqlDmlListStyle.WrapByWidth">Wrap by width</option>
                                            </select>
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("dml insert columns style one per line wrap by width")'>
                                            <SqlOptionLabel ForId="sql-insert-columns-style" Text="INSERT columns style" ExampleSql="@SqlFormattingExamples.DmlAndDdlExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-insert-columns-style" class="form-select form-select-sm" @bind="state.InsertColumnsStyle" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlDmlListStyle.OnePerLine">One per line</option>
                                                <option value="@SqlDmlListStyle.WrapByWidth">Wrap by width</option>
                                            </select>
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("dml insert columns start on new line newline")'>
                                            <SqlOptionLabel ForId="sql-insert-columns-start-on-new-line" Text="Start INSERT columns on new line" ExampleSql="@SqlFormattingExamples.DmlAndDdlExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-insert-columns-start-on-new-line" class="form-check-input" type="checkbox" @bind="state.InsertColumnsStartOnNewLine" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("dml insert values style one per line rows per line wrap by width")'>
                                            <SqlOptionLabel ForId="sql-insert-values-style" Text="INSERT VALUES style" ExampleSql="@SqlFormattingExamples.DmlAndDdlExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-insert-values-style" class="form-select form-select-sm" @bind="state.InsertValuesStyle" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlDmlListStyle.OnePerLine">One per line</option>
                                                <option value="@SqlDmlListStyle.RowsPerLine">Rows per line</option>
                                                <option value="@SqlDmlListStyle.WrapByWidth">Wrap by width</option>
                                            </select>
                                        </div>
                                    </div>
                                </details>

                                <details class="dsl-sql-option-section" open>
                                    <summary>DDL</summary>
                                    <div class="dsl-sql-property-grid">
                                        <div class="dsl-sql-property-row" hidden='@HideOption("ddl create proc layout expanded compact")'>
                                            <SqlOptionLabel ForId="sql-create-proc-layout" Text="CREATE PROC layout" ExampleSql="@SqlFormattingExamples.CreateProcLayoutExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-create-proc-layout" class="form-select form-select-sm" @bind="state.CreateProcLayout" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlCreateProcLayout.Expanded">Expanded</option>
                                                <option value="@SqlCreateProcLayout.Compact">Compact</option>
                                            </select>
                                        </div>
                                    </div>
                                </details>

                                <details class="dsl-sql-option-section" open>
                                    <summary>Comments</summary>
                                    <div class="dsl-sql-property-grid">
                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("comments preserve attachment")'>
                                            <SqlOptionLabel ForId="sql-comments-preserve-attachment" Text="Preserve attachment" ExampleSql="@SqlFormattingExamples.CommentsExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-comments-preserve-attachment" class="form-check-input" type="checkbox" @bind="state.CommentsPreserveAttachment" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row" hidden='@HideOption("comments formatting keep reflow safe only normalize whitespace")'>
                                            <SqlOptionLabel ForId="sql-comments-formatting" Text="Comment whitespace" ExampleSql="@SqlFormattingExamples.CommentsExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <select id="sql-comments-formatting" class="form-select form-select-sm" @bind="state.CommentsFormatting" @bind:after="OnOptionValueChangedAsync">
                                                <option value="@SqlCommentsFormattingMode.Keep">Keep original spacing</option>
                                                <option value="@SqlCommentsFormattingMode.ReflowSafeOnly">Normalize safe whitespace</option>
                                            </select>
                                        </div>
                                    </div>
                                </details>

                                <details class="dsl-sql-option-section" open>
                                    <summary>Spacing</summary>
                                    <div class="dsl-sql-property-grid">
                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("spaces inside parentheses always never")'>
                                            <SqlOptionLabel ForId="sql-inside-parentheses" Text="Spaces inside parentheses" ExampleSql="@SqlFormattingExamples.SpacingExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-inside-parentheses" class="form-check-input" type="checkbox" @bind="state.SpacesInsideParentheses" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("spaces after comma")'>
                                            <SqlOptionLabel ForId="sql-spaces-after-comma" Text="Spaces after comma" ExampleSql="@SqlFormattingExamples.SpacingExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-spaces-after-comma" class="form-check-input" type="checkbox" @bind="state.SpacesAfterComma" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("spaces around binary operators")'>
                                            <SqlOptionLabel ForId="sql-spaces-around-binary-operators" Text="Spaces around binary operators" ExampleSql="@SqlFormattingExamples.SpacingExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-spaces-around-binary-operators" class="form-check-input" type="checkbox" @bind="state.SpacesAroundBinaryOperators" @bind:after="OnOptionValueChangedAsync" />
                                        </div>

                                        <div class="dsl-sql-property-row dsl-sql-property-row--check" hidden='@HideOption("spaces before semicolon")'>
                                            <SqlOptionLabel ForId="sql-spaces-before-semicolon" Text="Spaces before semicolon" ExampleSql="@SqlFormattingExamples.SpacingExampleSql" OnExampleRequested="OnOptionExampleRequestedAsync" />
                                            <input id="sql-spaces-before-semicolon" class="form-check-input" type="checkbox" @bind="state.SpacesBeforeSemicolon" @bind:after="OnOptionValueChangedAsync" />
                                        </div>
                                    </div>
                                </details>
                                </div>
                    </div>
                </section>
            </div>
        </FirstPanel>

        <SecondPanel>
            <div class="dsl-sql-workspace-panel">
                <section class="card dsl-sql-output-panel">
                    <div class="card-header dsl-sql-output-header">
                        <span>Formatted SQL</span>
                        <span class="text-muted small">Always visible</span>
                    </div>
                    <div class="card-body d-flex flex-column dsl-sql-output-body">
                        @if (state.IsFormatterInitializing)
                        {
                            <div class="alert alert-info dsl-sql-error" role="status">
                                Preparing formatter...
                            </div>
                        }
                        else if (!string.IsNullOrWhiteSpace(state.FormattingError))
                        {
                            <div class="alert alert-danger dsl-sql-error" role="alert">
                                @state.FormattingError
                            </div>
                        }
                        else
                        {
                            <textarea id="sql-formatted-output"
                                      class="form-control dsl-sql-editor dsl-sql-output"
                                      readonly
                                      wrap="off"
                                      spellcheck="false"
                                      value="@state.FormattedSql"></textarea>
                        }
                    </div>
                </section>
            </div>
        </SecondPanel>
        </MudSplitPanel>
    </fieldset>
</section>

